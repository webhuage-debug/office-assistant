{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "smart-home-office-assistant",
  "version": "0.1.0",
  "identifier": "com.codex.smart-home-office-assistant",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "smart-home-office-assistant",
        "width": 1440,
        "height": 960,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": ["../config/app.config.json"]
  }
}
